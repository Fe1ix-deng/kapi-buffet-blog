---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        卡皮巴菲特笔记大全
      </h1>

      <p>
        卡皮巴菲特的投资笔记，专注美股长期投资、价值投资与财务自由之路。知行合一，慢慢变富。
      </p>

      {
        config.features.search === "pagefind" && (
          <form
            action={getRelativeLocaleUrl(locale, "search")}
            method="get"
            role="search"
            class="mt-6 flex max-w-xl flex-col gap-3 sm:flex-row sm:items-center"
            data-home-search
          >
            <label
              for="home-search-keyword"
              class="text-muted-foreground text-sm font-medium whitespace-nowrap"
            >
              根据关键词
            </label>
            <input
              id="home-search-keyword"
              name="q"
              type="search"
              placeholder="搜索定投、资产配置、QQQ..."
              class="border-border bg-background text-foreground placeholder:text-muted-foreground/75 focus:border-accent min-h-11 flex-1 rounded-md border px-3 py-2 text-base outline-offset-2"
            />
            <button
              type="submit"
              class="border-accent text-accent hover:bg-accent hover:text-accent-foreground focus-outline min-h-11 rounded-md border px-4 py-2 text-sm font-semibold transition-colors"
            >
              检索
            </button>
          </form>
        )
      }

      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    const searchForm = document.querySelector<HTMLFormElement>(
      "form[data-home-search]"
    );
    searchForm?.addEventListener("submit", event => {
      const formData = new FormData(searchForm);
      const keyword = String(formData.get("q") ?? "").trim();

      if (!keyword) {
        event.preventDefault();
        searchForm.querySelector<HTMLInputElement>('input[name="q"]')?.focus();
      }
    });
  });
</script>
